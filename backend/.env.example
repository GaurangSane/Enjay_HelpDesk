SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_KEY=your-service-role-key
RESEND_WEBHOOK_SECRET=whsec_your-resend-webhook-signing-secret
RESEND_API_KEY=re_your-resend-api-key
RESEND_FROM_EMAIL=support@yourdomain.com
SUPPORT_EMAIL_ADDRESS=support@yourdomain.com
GOOGLE_API_KEY=your-google-ai-studio-api-key
GROQ_API_KEY=your-groq-api-key
SENTRY_DSN=https://public@sentry.io/123456

# ── Redis (Railway Redis addon injects REDIS_URL automatically) ──────────
REDIS_URL=redis://localhost:6380/0

# ── Qdrant Cloud (leave QDRANT_API_KEY blank for local Docker) ───────────
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# ── CORS (comma-separated Vercel origins; localhost used if unset) ───────
ALLOWED_ORIGINS=https://your-app.vercel.app

# ── Sentry environment tag ───────────────────────────────────────────────
APP_ENV=production
